---
import Layout from "@/layouts/Layout.astro";
import BlogList from "@/components/BlogList";
import TagList from "@/components/TagList";
import { getPosts, getTags } from "@/lib/api";
import { CONFIG } from "@/data/config";

const { tag } = Astro.params;

if (!tag) {
  return Astro.redirect("/blog");
}

const page = Number(Astro.url.searchParams.get("page")) || 1;
const limit = CONFIG.blog.postsPerPage;

let posts: any[] = [];
let pagination = { page: 1, limit, total: 0, totalPages: 0 };
let tags: any[] = [];

try {
  const [postsResp, tagsResp] = await Promise.all([
    getPosts({ page, limit, tag, includeDrafts: true }),
    getTags(),
  ]);
  posts = postsResp.posts;
  pagination = postsResp.pagination;
  tags = tagsResp.tags;
} catch (e) {
  console.error("Failed to fetch blog data:", e);
}

const tagName = tags.find(t => t.slug === tag)?.name || tag;
---

<Layout title={`Posts tagged "${tagName}"`} description={`Blog posts tagged with ${tagName}`}>
  <div class="flex flex-col gap-8">
    <div class="flex flex-col gap-2">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors w-fit"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        All posts
      </a>
      <h1 class="text-2xl font-bold tracking-tight">
        Tagged: <span class="text-muted-foreground">{tagName}</span>
      </h1>
    </div>
    {tags.length > 0 && <TagList client:load tags={tags} activeTag={tag} />}
    <BlogList
      client:load
      posts={posts.map(p => ({
        id: p.slug,
        title: p.title,
        publishedAt: p.status === "draft" ? "Coming Soon" : new Date(p.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }),
        isDraft: p.status === "draft",
      }))}
      allPostsCount={pagination.total}
      pagination={{
        page: pagination.page,
        totalPages: pagination.totalPages,
        hasNextPage: pagination.page < pagination.totalPages,
        hasPreviousPage: pagination.page > 1,
      }}
      pageSize={limit}
    />
  </div>
</Layout>
