---
import Layout from "@/layouts/Layout.astro";
import BlogList from "@/components/BlogList";
import BlogSearch from "@/components/BlogSearch";
import TagList from "@/components/TagList";
import { getPosts, getTags } from "@/lib/api";
import { CONFIG } from "@/data/config";

const page = Number(Astro.url.searchParams.get("page")) || 1;
const tag = Astro.url.searchParams.get("tag") || "";
const limit = CONFIG.blog.postsPerPage;

let posts: any[] = [];
let pagination = { page: 1, limit, total: 0, totalPages: 0 };
let tags: any[] = [];
let error = false;

try {
  const [postsResp, tagsResp] = await Promise.all([
    getPosts({ page, limit, tag: tag || undefined, includeDrafts: true }),
    getTags(),
  ]);
  posts = postsResp.posts;
  pagination = postsResp.pagination;
  tags = tagsResp.tags;
} catch (e) {
  console.error("Failed to fetch blog data:", e);
  error = true;
}
---

<Layout title="Blog" description="Thoughts on software development, life, and more.">
  {error ? (
    <section class="flex flex-col items-center justify-center min-h-[60vh] text-center gap-6">
      <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-bold tracking-tight">Blog Unavailable</h1>
        <p class="text-muted-foreground max-w-md">
          Unable to load posts. Please try again later.
        </p>
      </div>
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors border border-border rounded-lg px-4 py-2"
      >
        Back to Home
      </a>
    </section>
  ) : (
    <div class="flex flex-col gap-8">
      <BlogSearch client:load />
      {tags.length > 0 && <TagList client:load tags={tags} activeTag={tag} />}
      <BlogList
        client:load
        posts={posts.map(p => ({
          id: p.slug,
          title: p.title,
          publishedAt: p.status === "draft" ? "Coming Soon" : new Date(p.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }),
          isDraft: p.status === "draft",
        }))}
        allPostsCount={pagination.total}
        pagination={{
          page: pagination.page,
          totalPages: pagination.totalPages,
          hasNextPage: pagination.page < pagination.totalPages,
          hasPreviousPage: pagination.page > 1,
        }}
        pageSize={limit}
      />
    </div>
  )}
</Layout>
