# Backend runs on DigitalOcean Droplet
# Copy to .env and fill in values

# PostgreSQL — AWS RDS (ap-south-1 / Mumbai)
DATABASE_URL=postgres://postgres:yourpass@your-instance.ap-south-1.rds.amazonaws.com:5432/portfolio?sslmode=require

# Redis — Upstash (use the TCP endpoint, not REST)
# Found in Upstash console under "Redis" connection tab
REDIS_ADDR=your-endpoint.upstash.io:6379
REDIS_PASSWORD=your-upstash-password

# GitLab blog source
GITLAB_REPO=https://gitlab.com/shashwat-dixit/blog.git
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Protect the sync endpoint
SYNC_API_KEY=generate-a-strong-random-string

# Frontend domain (Cloudflare Pages)
CORS_ORIGIN=https://shashwatdixit.com
SITE_URL=https://shashwatdixit.com
