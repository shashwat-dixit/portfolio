# ── Database (self-hosted PostgreSQL in Docker) ──────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── Redis (self-hosted in Docker) ────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-password

# ── GitLab blog source ───────────────────────────────────────────────────────
GITLAB_REPO=https://gitlab.com/shashwat-dixit/blog.git
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# ── Protect the sync endpoint ────────────────────────────────────────────────
SYNC_API_KEY=generate-a-strong-random-string

# ── Frontend (baked into Docker image at build time) ─────────────────────────
# PUBLIC_API_URL=https://api.shashwatdixit.com
# PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
